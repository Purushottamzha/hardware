# =============================================================================
# SafeRide Nepal — Environment Variables (template)
# Copy this file to .env and fill in real values. .env is gitignored.
# =============================================================================

# Database
DATABASE_URL=postgresql://saferide:saferide_pass@postgres:5432/saferide

# Encryption key for AES-256-GCM (generate via: openssl rand -hex 32)
ENCRYPTION_KEY=

# JWT
JWT_SECRET=
JWT_EXPIRY=8h

# Default admin credentials (created on first seed)
ADMIN_PHONE=+977-9800000000
ADMIN_PASSWORD=change_me_in_production

# Mosquitto
MOSQUITTO_HOST=mosquitto
MOSQUITTO_PORT=8883
MOSQUITTO_USERNAME=backend
MOSQUITTO_PASSWORD=
MOSQUITTO_CA_CERT=/mosquitto/certs/ca.crt
MOSQUITTO_TLS_REJECT_UNAUTHORIZED=true

# Student token secret (HMAC key for signing student QR tokens)
STUDENT_TOKEN_SECRET=

# Dashboard origin (for CORS)
DASHBOARD_ORIGIN=http://localhost:5173

# Photo retention in days
PHOTO_RETENTION_DAYS=30

# Node environment
NODE_ENV=development
