{
  "apps": {
    "http": {
      "servers": {
        "srv0": {
          "listen": [":443"],
          "routes": [
            {
              "handle": [{
                "handler": "subroute",
                "routes": [
                  {
                    "handle": [{
                      "handler": "rewrite",
                      "strip_path_prefix": "/api"
                    }]
                  },
                  {
                    "handle": [{
                      "handler": "reverse_proxy",
                      "upstreams": [{"dial": "backend:3000"}]
                    }]
                  }
                ]
              }],
              "match": [{"path": ["/api/*"]}]
            },
            {
              "handle": [{
                "handler": "reverse_proxy",
                "upstreams": [{"dial": "backend:3000"}]
              }],
              "match": [{"path": ["/socket.io/*"]}]
            },
            {
              "handle": [{
                "handler": "reverse_proxy",
                "upstreams": [{"dial": "dashboard:80"}]
              }]
            }
          ],
          "tls_connection_policies": [{
            "certificate_selection": {
              "any_tag": ["cert0"]
            }
          }]
        }
      }
    },
    "tls": {
      "certificates": {
        "load_files": [{
          "certificate": "/certs/saferide-dev.crt",
          "key": "/certs/saferide-dev.key",
          "tags": ["cert0"]
        }]
      }
    }
  }
}
