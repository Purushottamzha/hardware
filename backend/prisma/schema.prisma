generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Route {
  id        String @id
  name      String
  waypoints Json
  buses     Bus[]
}

model Bus {
  id      String    @id
  routeId String
  route   Route     @relation(fields: [routeId], references: [id])
  students Student[]
}

model Device {
  id                 String             @id
  encryptedSecret    String
  busId              String
  status             String             @default("active")
  lastSeenCounter    Int                @default(0)
  invalidSigCount    Int                @default(0)
  invalidSigWindowStart DateTime?
  events             AttendanceEvent[]
}

model Student {
  id            String   @id @default(cuid())
  name          String
  class         String
  busId         String
  bus           Bus      @relation(fields: [busId], references: [id])
  guardianName  String?
  guardianPhone String?
  wardTole      String?
  homeLat       Float?
  homeLon       Float?
  homeRadiusM   Int      @default(150)
  routeOrder    Int?
  currentState  String   @default("NOT_BOARDED")
  qrRevoked     Boolean  @default(false)
  tokenVersion  Int      @default(1)
  events        AttendanceEvent[]

  @@index([busId])
}

model AttendanceEvent {
  id              Int      @id @default(autoincrement())
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id])
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  eventType       String
  lat             Float
  lon             Float
  eventTimestamp  DateTime
  deviceCounter   Int
  verified        Boolean  @default(false)
  flagged         Boolean  @default(false)
  flagReason      String?
  rejectionReason String?
  photoPath       String?
  resolved        Boolean  @default(false)
  resolutionNote  String?
  manualByAdminId Int?
  createdAt       DateTime @default(now())

  @@unique([deviceId, deviceCounter])
  @@index([studentId, createdAt])
  @@index([deviceId, createdAt])
}

model SecurityEvent {
  id         Int      @id @default(autoincrement())
  type       String
  deviceId   String?
  rawPayload Json
  createdAt  DateTime @default(now())
}

model AdminUser {
  id             Int        @id @default(autoincrement())
  phone          String     @unique
  passwordHash   String
  role           String     @default("admin")
  failedAttempts Int        @default(0)
  lockedUntil    DateTime?
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  adminId   Int
  action    String
  targetId  String?
  prevHash  String
  hash      String
  details   String?
  createdAt DateTime @default(now())
}

model CalendarOverride {
  id                Int      @id @default(autoincrement())
  date              DateTime @unique
  dayType           String
  boardWindowStart  String?
  boardWindowEnd    String?
  departWindowStart String?
  departWindowEnd   String?
}